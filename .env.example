# Copy this file to .env and fill in your Gemini API key.
# Get a free key at: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your-gemini-key-here
PORT=3000

# NOTE - Commonly, Gemini servers for this model will experience a high demand;
# Unfortunately, using the free model there is no way to avoid this.
# If you encounter Error [503], please resend your message after waiting a few seconds.
# If the error lasts longer than a minute, please reload the page - typically gemini
# only takes a minute or two before it is resolved.